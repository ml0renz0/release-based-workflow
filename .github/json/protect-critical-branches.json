{
  "name": "protect critical branches",
  "target": "branch",
  "source_type": "Repository",
  "enforcement": "active",
  "conditions": {
    "ref_name": {
      "exclude": [],
      "include": [
        "refs/heads/master",
        "refs/heads/develop"
      ]
    }
  },
  "rules": [
    { "type": "deletion" },
    { "type": "non_fast_forward" },
    {
      "type": "pull_request",
      "parameters": {
        "required_approving_review_count": 0,
        "dismiss_stale_reviews_on_push": false,
        "require_code_owner_review": false,
        "require_last_push_approval": false,
        "required_review_thread_resolution": false,
        "automatic_copilot_code_review_enabled": false,
        "allowed_merge_methods": ["merge","squash","rebase"]
      }
    },
    {
      "type": "required_status_checks",
      "parameters": {
        "strict_required_status_checks_policy": true,
        "do_not_enforce_on_create": false,
        "required_status_checks": [
          { "context": "check-commit-message-prefix",   "integration_id": 15368 },
          { "context": "check-commit-push-branch-name", "integration_id": 15368 },
          { "context": "check-master-pr-title",         "integration_id": 15368 },
          { "context": "pr-branch-validation",          "integration_id": 15368 },
          { "context": "bump-and-release-develop",      "integration_id": 15368 },
          { "context": "bump-and-release-master",       "integration_id": 15368 }
        ]
      }
    },
    {
      "type": "required_linear_history"
    }
  ],
  "bypass_actors": []
}
